// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum TaskStatus {
  in_progress
  on_hold
  completed
  cancelled
}

enum TaskEventType {
  created
  completed
  cancelled
  resumed
  held
}

// UserSettings now only stores authentication
model UserSettings {
  id           Int      @id @default(1)
  passwordHash String?
  fullName     String?
  email        String?
  title        String?
  bio          String?
  reportTitleOptions Json?
  defaultReportTitle String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Job is the top-level entity with its own work schedule
model Job {
  id          Int      @id @default(autoincrement())
  name        String
  nameKey     String   @unique
  description String?
  isArchived  Boolean  @default(false)
  
  // Work schedule settings (moved from UserSettings)
  workStart   String   @default("09:00")
  workEnd     String   @default("17:00")
  workDays    Json     @default("[1, 2, 3, 4, 5]") // Mon-Fri
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  projects    Project[]
  breaks      BreakType[]
  attendance  JobAttendance[]
}

model Project {
  id        Int      @id @default(autoincrement())
  name      String
  nameKey   String   @unique
  description String?
  isArchived Boolean @default(false)
  
  // Foreign key to Job
  jobId     Int
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]
}

model Task {
  id                Int        @id @default(autoincrement())
  projectId         Int
  title             String
  description       String?
  status            TaskStatus @default(in_progress)
  startedAt         DateTime
  endedAt           DateTime?
  elapsedSeconds    Int        @default(0)
  completionOutput  String?
  cancellationReason String?
  logNotes          String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  project           Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events            TaskEvent[]
  subtasks          SubTask[]
}

model BreakType {
  id          Int    @id @default(autoincrement())
  name        String
  type        String // "Prayer", "Meal", "Washroom", "Custom", etc.
  duration    Int?   // Duration in minutes (null for recurring breaks)
  isOneTime   Boolean @default(false)
  isActive    Boolean @default(true)
  
  // Foreign key to Job (moved from UserSettings)
  jobId       Int
  job         Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TaskEvent {
  id        Int           @id @default(autoincrement())
  taskId    Int
  eventType TaskEventType
  eventAt   DateTime      @default(now())
  meta      Json?
  task      Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model SubTask {
  id          Int      @id @default(autoincrement())
  taskId      Int
  title       String
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// Job Attendance for checkin/checkout functionality
model JobAttendance {
  id              Int       @id @default(autoincrement())
  jobId           Int
  job             Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  checkInTime     DateTime
  checkOutTime    DateTime?
  totalWorkSeconds Int      @default(0)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([jobId])
  @@index([checkInTime])
}
